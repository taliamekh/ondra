# Onda environment variables
# Copy this file to .env and fill in your Supabase project values.
# The anon / publishable key is safe to expose in client apps — access is
# protected by Row Level Security policies on the database.

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
